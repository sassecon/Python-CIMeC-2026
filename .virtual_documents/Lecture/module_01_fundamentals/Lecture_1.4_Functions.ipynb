def greater_than_two(x):
    return x > 2
    
numbers = [1, 2, 3, 4, 5]
result = filter(greater_than_two, numbers)

print(list(result))   # [3, 4, 5]








numbers = [1, 2, 3]

result = map(lambda x: x**2, numbers)

print(list(result))   # [1, 4, 9]





