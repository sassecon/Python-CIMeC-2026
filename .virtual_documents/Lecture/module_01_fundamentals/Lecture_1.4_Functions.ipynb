def exponentiate(a, b=2):
    """Compute a power using argument a as base and b as exponent.

    Parameters:
        a : int or float
            Base of the exponentiation
        b : int or float, optional
            Exponent of the exponentiation (default is 2)

    Returns:
        int or float
            The computed power
    """
    return a ** b





