def redact_words(input_string):
    words = input_string.split()
    output_words = []

    for word in words:
        if len(word) > 6:
            output_words.append("###")
        else:
            output_words.append(word)

    return output_words

example_input = "Neuroscience students usually enjoy computational methods"
print(redact_words(example_input))





def redact_words(input_string, threshold=6):
    words = input_string.split()
    output_words = []

    for word in words:
        if len(word) > threshold:
            output_words.append("###")
        else:
            output_words.append(word)

    return output_words

example_input = "Neuroscience students usually enjoy computational methods"
print(redact_words(example_input))
print(redact_words(example_input, threshold=8))





