def calc_distance(point1, point2):
    x1, y1 = point1
    x2, y2 = point2
    return ((x2 - x1) ** 2 + (y2 - y1) ** 2) ** 0.5

def calc_perimeter(coordinates):
    perimeter = 0
    for i in range(len(coordinates)):
        perimeter += calc_distance(coordinates[1], coordinates[2])
    return perimeter

square_coordinates = [(0, 0), (1, 0), (1, 1), (0, 1), (0, 0)]
print(calc_perimeter(square_coordinates))





def variance(numbers):
    mean_value = sum(numbers) / len(numbers)
    squared_diffs = [(x - mean_value) ** 2 for x in numbers]
    return sum(squared_diffs) / len(numbers)

participants_height = [167, 185, 179, 191, 178, 180, 175, 188, 170]
height_var = variance(participants_height)
print(height_var)





def variance(numbers, df=1):
    mean_value = sum(numbers) / len(numbers)
    squared_diffs = [(x - mean_value) ** 2 for x in numbers]
    return sum(squared_diffs) / (len(numbers) - df)

participants_height = [167, 185, 179, 191, 178, 180, 175, 188, 170]
print(variance(participants_height))
print(variance(participants_height, df=0))





data_list = [2.1, 1.3, 4.0, 0.5, 2.7, 3.1]

def calc_mean(numbers):
    return sum(numbers) / len(numbers)

def calc_std(numbers, mean=None):
    if mean is None:
        mean = calc_mean(numbers)
    variance = sum((x - mean) ** 2 for x in numbers) / (len(numbers) - 1)
    return variance ** 0.5

def z_score(numbers):
    mean_value = calc_mean(numbers)
    std_value = calc_std(numbers, mean_value)
    return [(x - mean_value) / std_value for x in numbers]

print(z_score(data_list))








