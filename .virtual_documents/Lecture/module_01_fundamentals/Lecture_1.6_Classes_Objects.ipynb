class Dog:
    def __init__(self, name, toys):
        self.name = name
        self.toys = toys.copy()   # store a copy, not the original list

    def add_toy(self, new_toy):
        self.toys.append(new_toy)   # modifies the object

    def remove_toy(self, old_toy):
        if old_toy in self.toys:
            self.toys.remove(old_toy)   # modifies the object

    def show_toys(self):
        return self.toys



my_toys = ["ball", "rope"]
dog1 = Dog("Buddy", my_toys)

print(dog1.show_toys())


# Add toy
dog1.add_toy("bone")
print(dog1.show_toys())


# Remove toy
dog1.remove_toy("rope")
print(dog1.show_toys())





