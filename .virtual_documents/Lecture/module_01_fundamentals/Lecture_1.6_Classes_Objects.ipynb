class Dog:
    def __init__(self, name, weight_kg):
        self.name = name
        self._weight_kg = weight_kg   # internal attribute

    @property
    def weight_lb(self):
        return self._weight_kg * 2.20462

dog1 = Dog("Buddy", 10)
print(dog1.weight_lb)








class Dog:
    def __init__(self, name, age):
        self.name = name
        self._age = age

    @property
    def age(self):
        return self._age

    @age.setter
    def age(self, value):
        if value < 0:
            raise ValueError("Age cannot be negative")
        self._age = value


dog1 = Dog("Buddy", 3)
print(dog1.age)

dog1.age = 5
print(dog1.age)


dog1.age = -2








class Dog:
    def __init__(self, name, age):
        self.name = name
        self._age = age

    @property
    def age(self):          # getter
        return self._age

    @age.setter
    def age(self, value):   # setter
        if value < 0:
            raise ValueError("Age cannot be negative")
        self._age = value








dog1 = Dog("Buddy", 3)
print(dog1._age)   # possible, but discouraged






dog1.age = -10









class Dog:
    def __init__(self, name, age):
        self.name = name
        self.age = age

    def describe(self):
        return f"{self.name} is {self.age} years old."


class GuideDog(Dog):
    def __init__(self, name, age, owner):
        super().__init__(name, age)   # call the parent class
        self.owner = owner






dog1 = GuideDog("Buddy", 4, "Alice")

print(dog1.name)
print(dog1.age)
print(dog1.owner)
print(dog1.describe())














def arbitrary_inputs_function(first_argument, *args):
    print(f"Captured argument: {first_argument}")
    print(type(args), args)

arbitrary_inputs_function(1, 2, 3)








def arbitrary_inputs_function(first_argument, *args, **kwargs):
    print(f"Captured argument: {first_argument}")
    print(f"args ({type(args)}): {args}")
    print(f"kwargs ({type(kwargs)}): {kwargs}")

arbitrary_inputs_function(1, 2, 3, random_kwarg=5)






