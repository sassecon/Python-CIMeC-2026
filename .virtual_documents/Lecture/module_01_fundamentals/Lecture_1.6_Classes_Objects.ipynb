# a class for a dog context
class Dog:
    def __init__(self, name, enrollment, breed="Mixed", vaccinated=True):
        self.name = name
        self.enrollment = enrollment
        self.breed = breed
        self.vaccinated = vaccinated



# Positional arguments
# name = Buddy
# enrollment = 101

dog1 = Dog("Buddy", 101)
print(dog1.name, dog1.enrollment, dog1.breed, dog1.vaccinated)


# Keyword arguments
# name="Charlie"
# enrollment=102
# breed="Labrador"

dog2 = Dog(name="Charlie", enrollment=102, breed="Labrador")
print(dog2.name, dog2.enrollment, dog2.breed, dog2.vaccinated)


# Default values
# breed --> default = "Mixed"
# vaccinated --> default = True

dog3 = Dog("Rocky", 103)
print(dog3.breed)       # Mixed
print(dog3.vaccinated)  # True


# Required arguments
# name --> required (no default)
# enrollment  --> required (no default)

dog4 = Dog("Max", 104)


dog5 = Dog("Max")





